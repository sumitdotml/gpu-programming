# Reference for what `.clangd` should contain on each machine.
# When switching machines: copy the matching block below into `.clangd`,
# work locally, and keep the edit OUT of commits (e.g. `git stash` it).

########################################################
# Linux box (NVIDIA H200, compute capability 9.0)
########################################################
CompileFlags:
  Add: [--cuda-host-only, --cuda-path=/usr/local/cuda, --cuda-gpu-arch=sm_90]

########################################################
# macOS: CUDA cannot run here; this is an editor-only setup
########################################################
# installing CUDA 12.8 headers locally lets clangd resolve CUDA syntax and symbols
# even though this machine cannot compile or run the program
# setup script: https://github.com/sumitdotml/dotfiles/blob/main/scripts/setup-cuda-headers.sh
# sm_75 is arbitrary here; it selects consistent header branches for the parser
CompileFlags:
  Add:
    [
      --cuda-host-only,
      --cuda-path=/Users/sumit/.local/cuda,
      --cuda-gpu-arch=sm_75,
      -Xclang,
      -target-sdk-version=12.8,
    ]

# flag reference:
#   --cuda-host-only      : request only the host compilation for editor analysis
#   --cuda-path=<dir>     : where the CUDA toolkit lives on this machine
#   --cuda-gpu-arch=sm_XX : compute capability (Hopper=sm_90, Ampere=sm_86, Turing=sm_75)
#   -Xclang -target-sdk-version=12.8 : keep macOS's SDK version from overriding CUDA's
